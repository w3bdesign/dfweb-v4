# pnpm Security Configuration
# Defense against supply chain attacks

# Minimum Release Age: Packages must be at least 48 hours old before installation
# This prevents installing freshly compromised packages (Shy Hallude was detected in 6 min)
# Value is in minutes: 2880 = 48 hours (2 * 24 * 60)
# Use --ignore-release-age flag for rare emergency exceptions
minimum-release-age=2880

# Block exotic subdependencies: Prevent transitive deps from linking to
# GitHub commits, tarballs, or other non-registry sources (pnpm 11+)
block-exotic-subdependencies=true

# Registry configuration (using default npm registry which supports release timestamps)
registry=https://registry.npmjs.org/

# Strict peer dependencies for better dependency tree control
strict-peer-dependencies=false

# Auto-install peers to avoid manual peer dependency management
auto-install-peers=true

# Engine strict mode - fail if Node.js version doesn't match engines field
engine-strict=true
ignore-scripts=true
