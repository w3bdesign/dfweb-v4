{
  "extends": "stylelint-config-standard",
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": ["config", "tailwind", "apply", "layer", "theme"]
      }
    ],
    "selector-id-pattern": null,
    "property-no-deprecated": [
      true,
      {
        "ignoreProperties": ["clip"]
      }
    ]
  }
}
