{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["src/stories/**/*.stories.tsx"],
  "ignorePatterns": [
    "src/types/sanity.types.ts",
    ".eslintrc-custom-rules.ts",
    "studio/**",
    "src/utils/eslint/**"
  ],
  "ignoreDependencies": ["eslint-config-next", "eslint-config-prettier", "@typescript-eslint/utils"],
  "rules": {
    "unused-files": "warn",
    "unused-exports": "warn",
    "unused-types": "warn"
  }
}
