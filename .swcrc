{
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": true,
      "dynamicImport": true
    },
    "transform": {
      "react": {
        "runtime": "automatic"
      }
    },
    "target": "es2022"
  },
  "env": {
    "targets": {
      "chrome": "92",
      "firefox": "90",
      "safari": "15.4",
      "edge": "92"
    },
    "mode": "usage"
  }
}
