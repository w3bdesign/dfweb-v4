# Provider Selection (optional - auto-detects based on available API keys if not set)
# Valid values: anthropic, openai, openai-compatible
# PROVIDER=""

# API Keys - set at least one (or more for fallback options)
# The system auto-detects which provider to use based on which key is present
# Priority order: Anthropic > OpenAI > OpenAI-compatible
# ANTHROPIC_API_KEY="sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# OPENAI_API_KEY=""     # For OpenAI GPT models (sk-...)

# OpenAI-Compatible provider (for local LLMs, custom endpoints, etc.)
# Both are required if using openai-compatible provider
OPENAI_COMPATIBLE_API_KEY="vck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OPENAI_COMPATIBLE_BASE_URL="https://ai-gateway.vercel.sh/v1"  # e.g., http://localhost:1234/v1

# Optional: Override the default model for your chosen provider
MODEL_NAME="anthropic/claude-sonnet-5"